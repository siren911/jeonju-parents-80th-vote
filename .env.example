# ─────────────────────────────────────────────────────────────
# 이 파일을 복사해서 .env 파일을 만들고 값을 채우세요.
#   cp .env.example .env
# .env 는 절대 git에 커밋하지 않습니다. (.gitignore에 포함되어 있음)
# ─────────────────────────────────────────────────────────────

# Supabase 프로젝트 URL
# Supabase Dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL=

# ★ 반드시 publishable (anon) key 만 사용하세요.
# service_role / secret key 는 브라우저에 절대 넣으면 안 됩니다.
# Supabase Dashboard → Project Settings → API → Project API keys → anon public
VITE_SUPABASE_PUBLISHABLE_KEY=

# 행사 식별자. supabase/seed.sql 에 넣은 slug 와 같아야 합니다.
VITE_EVENT_SLUG=parents80-jeonju-7f9k2m

# true 로 두면 Supabase 없이 이 기기에서만 저장되는 데모 모드로 동작합니다.
# 가족에게 실제로 링크를 보내기 전에는 반드시 false 로 바꾸고 Supabase를 연결하세요.
VITE_DEMO_MODE=false
